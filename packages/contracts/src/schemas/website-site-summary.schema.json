{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/website-site-summary.json",
  "title": "WebsiteSiteSummary",
  "description": "Summary row for a completed website crawl (Pass 2 Phase 1 contract).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "siteSummaryId",
    "crawlPlanId",
    "companyId",
    "caseId",
    "sourceId",
    "sourceVersion",
    "lineageStatus",
    "siteRootUrl",
    "totalPagesDiscovered",
    "totalPagesApproved",
    "totalPagesFetched",
    "createdAt"
  ],
  "properties": {
    "siteSummaryId": { "type": "string", "minLength": 1 },
    "crawlPlanId": { "type": "string", "minLength": 1 },
    "companyId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceVersion": { "type": "integer", "minimum": 1 },
    "lineageStatus": {
      "type": "string",
      "enum": ["active", "previous", "superseded", "stale"]
    },
    "siteRootUrl": { "type": "string", "minLength": 1 },
    "totalPagesDiscovered": { "type": "integer", "minimum": 0 },
    "totalPagesApproved": { "type": "integer", "minimum": 0 },
    "totalPagesFetched": { "type": "integer", "minimum": 0 },
    "summaryRef": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
