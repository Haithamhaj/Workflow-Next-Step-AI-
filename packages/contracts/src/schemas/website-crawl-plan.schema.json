{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/website-crawl-plan.json",
  "title": "WebsiteCrawlPlan",
  "description": "Plan for a bounded website crawl (Pass 2 Phase 1 contract; crawler built later).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "crawlPlanId",
    "companyId",
    "caseId",
    "sourceId",
    "sourceVersion",
    "lineageStatus",
    "seedUrls",
    "maxPages",
    "maxDepth",
    "plannedBy",
    "plannedAt",
    "status"
  ],
  "properties": {
    "crawlPlanId": { "type": "string", "minLength": 1 },
    "companyId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceVersion": { "type": "integer", "minimum": 1 },
    "lineageStatus": {
      "type": "string",
      "enum": ["active", "previous", "superseded", "stale"]
    },
    "intakeBatchId": { "type": "string", "minLength": 1 },
    "seedUrls": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "maxPages": { "type": "integer", "minimum": 1 },
    "maxDepth": { "type": "integer", "minimum": 0 },
    "plannedBy": { "type": "string", "minLength": 1 },
    "plannedAt": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "running", "completed", "cancelled"]
    },
    "notes": { "type": "string" }
  }
}
