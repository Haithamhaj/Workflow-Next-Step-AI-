{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/structured-context-field-evidence.json",
  "title": "StructuredContextFieldEvidence",
  "description": "Evidence row linking a structured context field value to its intake sources (Pass 2 Phase 1).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidenceId",
    "structuredContextId",
    "caseId",
    "fieldKey",
    "evidenceRefs",
    "extractedAt"
  ],
  "properties": {
    "evidenceId": { "type": "string", "minLength": 1 },
    "structuredContextId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "fieldKey": { "type": "string", "minLength": 1 },
    "fieldValue": { "type": "string" },
    "evidenceRefs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "extractedAt": { "type": "string", "format": "date-time" },
    "sourceProvider": { "type": "string" }
  }
}
