{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/website-crawl.json",
  "title": "WebsiteCrawlSession",
  "description": "Website crawl session with smart page selection, admin approval, and site-level summary (Pass 2 spec §10).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "crawlId",
    "sessionId",
    "sourceId",
    "baseUrl",
    "maxPages",
    "status",
    "candidatePages",
    "createdAt"
  ],
  "properties": {
    "crawlId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "minLength": 1 },
    "baseUrl": { "description": "Root URL to crawl.", "type": "string", "minLength": 1 },
    "maxPages": { "description": "Admin-configurable max page limit (§10.1), default 20.", "type": "integer", "minimum": 1, "maximum": 100 },
    "status": {
      "description": "Crawl session status.",
      "type": "string",
      "enum": ["discovering", "awaiting_approval", "approved", "crawling", "completed", "failed"]
    },
    "candidatePages": {
      "description": "Discovered pages with priority and exclusion info (§10.2, §10.3).",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "title", "priority", "excluded"],
        "properties": {
          "url": { "type": "string" },
          "title": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": [
              "homepage", "about", "services_solutions", "departments_teams_organization",
              "policies_terms_sla", "contact", "projects_case_studies_portfolio",
              "client_list_customers_partners", "blog_news", "careers_jobs", "other"
            ]
          },
          "excluded": { "type": "boolean" },
          "exclusionReason": { "type": "string" }
        }
      }
    },
    "approvedPages": {
      "description": "URLs the admin explicitly approved for crawling.",
      "type": "array",
      "items": { "type": "string" }
    },
    "siteSummary": {
      "description": "Site-level summary after crawl completion (§10.5).",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "companyIdentity", "servicesProvided", "domainSignal",
        "visibleDepartments", "visibleProjectsClientsPartners", "importantSignals"
      ],
      "properties": {
        "companyIdentity": { "type": "string" },
        "servicesProvided": { "type": "string" },
        "domainSignal": { "type": "string" },
        "visibleDepartments": { "type": "array", "items": { "type": "string" } },
        "visibleProjectsClientsPartners": { "type": "array", "items": { "type": "string" } },
        "importantSignals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
