{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/approved-hierarchy-snapshot.json",
  "title": "ApprovedHierarchySnapshot",
  "type": "object",
  "additionalProperties": true,
  "required": ["approvedSnapshotId", "hierarchyDraftId", "sessionId", "caseId", "nodes", "secondaryRelationships", "structuralApprovalOnly", "approvalScopeNote", "approvedBy", "approvedAt"],
  "properties": {
    "approvedSnapshotId": { "type": "string", "minLength": 1 },
    "hierarchyDraftId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "nodes": { "type": "array" },
    "secondaryRelationships": { "type": "array" },
    "structuralApprovalOnly": { "const": true },
    "approvalScopeNote": { "type": "string", "minLength": 1 },
    "approvedBy": { "type": "string", "minLength": 1 },
    "approvedAt": { "type": "string", "minLength": 1 }
  }
}
