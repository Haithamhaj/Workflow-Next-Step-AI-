{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/hierarchy-intake.json",
  "title": "HierarchyIntakeRecord",
  "type": "object",
  "additionalProperties": false,
  "required": ["hierarchyIntakeId", "sessionId", "caseId", "inputMethod", "status", "createdBy", "createdAt", "updatedAt"],
  "properties": {
    "hierarchyIntakeId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "inputMethod": { "type": "string", "enum": ["pasted_text", "uploaded_document"] },
    "status": { "type": "string", "enum": ["intake_created", "manual_draft_saved", "structurally_approved"] },
    "pastedText": { "type": "string" },
    "sourceId": { "type": "string" },
    "artifactId": { "type": "string" },
    "createdBy": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}
