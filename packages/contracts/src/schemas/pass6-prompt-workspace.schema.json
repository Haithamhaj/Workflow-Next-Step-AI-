{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/pass6-prompt-workspace.json",
  "title": "Pass6PromptWorkspace",
  "description": "Pass 6 Prompt Workspace contracts for PromptSpecs and offline test case records. These records support structured prompt editing, preview, comparison, and lifecycle state only; they do not execute providers or own workflow governance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["promptSpec", "promptTestCase", "promptTestExecutionResult"],
  "properties": {
    "promptSpec": { "$ref": "#/definitions/pass6PromptSpec" },
    "promptTestCase": { "$ref": "#/definitions/pass6PromptTestCase" },
    "promptTestExecutionResult": { "$ref": "#/definitions/pass6PromptTestExecutionResult" }
  },
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "promptStatus": {
      "type": "string",
      "enum": ["draft", "active", "previous", "archived"]
    },
    "testCaseStatus": {
      "type": "string",
      "enum": ["draft", "enabled", "disabled", "archived"]
    },
    "executionStatus": {
      "type": "string",
      "enum": ["succeeded", "failed"]
    },
    "capabilityKey": {
      "type": "string",
      "enum": [
        "synthesis",
        "difference_interpretation",
        "evaluation",
        "initial_package_drafting",
        "admin_explanation",
        "pre_package_inquiry_generation",
        "optional_draft_document_generation",
        "visual_narrative_support",
        "pass6_analysis_copilot"
      ]
    },
    "providerPreference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providerKey": { "type": "string" },
        "modelKey": { "type": "string" },
        "preferenceReason": { "type": "string" }
      }
    },
    "structuredSections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roleDefinition",
        "missionOrTaskPurpose",
        "caseContextInputs",
        "sourceAndEvidenceRules",
        "methodOrPolicyRules",
        "outputContract",
        "boundariesAndProhibitions",
        "adminReviewNotes",
        "evaluationChecklist",
        "examplesOrGoldenCases"
      ],
      "properties": {
        "roleDefinition": { "$ref": "#/definitions/nonEmptyString" },
        "missionOrTaskPurpose": { "$ref": "#/definitions/nonEmptyString" },
        "caseContextInputs": { "$ref": "#/definitions/nonEmptyString" },
        "sourceAndEvidenceRules": { "$ref": "#/definitions/nonEmptyString" },
        "methodOrPolicyRules": { "$ref": "#/definitions/nonEmptyString" },
        "outputContract": { "$ref": "#/definitions/nonEmptyString" },
        "boundariesAndProhibitions": { "$ref": "#/definitions/nonEmptyString" },
        "adminReviewNotes": { "$ref": "#/definitions/nonEmptyString" },
        "evaluationChecklist": { "$ref": "#/definitions/nonEmptyString" },
        "examplesOrGoldenCases": { "$ref": "#/definitions/nonEmptyString" }
      }
    },
    "pass6PromptSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "promptSpecId",
        "capabilityKey",
        "name",
        "description",
        "version",
        "status",
        "sections",
        "compiledPromptPreview",
        "testCaseIds",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "promptSpecId": { "$ref": "#/definitions/nonEmptyString" },
        "capabilityKey": { "$ref": "#/definitions/capabilityKey" },
        "name": { "$ref": "#/definitions/nonEmptyString" },
        "description": { "$ref": "#/definitions/nonEmptyString" },
        "version": { "$ref": "#/definitions/nonEmptyString" },
        "status": { "$ref": "#/definitions/promptStatus" },
        "providerPreference": { "$ref": "#/definitions/providerPreference" },
        "linkedPolicyConfigId": { "type": "string" },
        "linkedPolicyConfigVersion": { "type": "string" },
        "sections": { "$ref": "#/definitions/structuredSections" },
        "compiledPromptPreview": { "$ref": "#/definitions/nonEmptyString" },
        "testCaseIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "previousActivePromptSpecId": { "type": "string" },
        "basedOnPromptSpecId": { "type": "string" },
        "archivedReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "jsonValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/definitions/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/jsonValue" }
        }
      ]
    },
    "pass6PromptTestCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testCaseId",
        "promptSpecId",
        "name",
        "inputFixture",
        "expectedOutputNotes",
        "status",
        "enabled",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "testCaseId": { "$ref": "#/definitions/nonEmptyString" },
        "promptSpecId": { "$ref": "#/definitions/nonEmptyString" },
        "name": { "$ref": "#/definitions/nonEmptyString" },
        "inputFixture": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/jsonValue" }
        },
        "expectedOutputNotes": { "$ref": "#/definitions/nonEmptyString" },
        "status": { "$ref": "#/definitions/testCaseStatus" },
        "enabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "tokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 },
        "totalTokens": { "type": "integer", "minimum": 0 }
      }
    },
    "createdRecords": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "synthesisInputBundleIds",
        "workflowClaimIds",
        "workflowReadinessResultIds",
        "prePackageGateResultIds",
        "initialWorkflowPackageIds",
        "workflowGraphRecordIds",
        "pass7ReviewCandidateIds"
      ],
      "properties": {
        "synthesisInputBundleIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "workflowClaimIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "workflowReadinessResultIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "prePackageGateResultIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "initialWorkflowPackageIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "workflowGraphRecordIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "pass7ReviewCandidateIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } }
      }
    },
    "pass6PromptTestExecutionResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executionId",
        "promptSpecId",
        "promptSpecVersion",
        "promptStatusAtRun",
        "testCaseId",
        "providerName",
        "modelName",
        "startedAt",
        "completedAt",
        "status",
        "inputFixtureSummary",
        "compiledPromptSnapshot",
        "createdRecords"
      ],
      "properties": {
        "executionId": { "$ref": "#/definitions/nonEmptyString" },
        "promptSpecId": { "$ref": "#/definitions/nonEmptyString" },
        "promptSpecVersion": { "$ref": "#/definitions/nonEmptyString" },
        "promptStatusAtRun": { "type": "string", "enum": ["draft", "active"] },
        "testCaseId": { "$ref": "#/definitions/nonEmptyString" },
        "providerName": { "$ref": "#/definitions/nonEmptyString" },
        "modelName": { "$ref": "#/definitions/nonEmptyString" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "status": { "$ref": "#/definitions/executionStatus" },
        "latencyMs": { "type": "integer", "minimum": 0 },
        "inputFixtureSummary": { "$ref": "#/definitions/nonEmptyString" },
        "compiledPromptSnapshot": { "$ref": "#/definitions/nonEmptyString" },
        "outputText": { "type": "string" },
        "outputJson": { "$ref": "#/definitions/jsonValue" },
        "errorCode": { "type": "string" },
        "errorMessage": { "type": "string" },
        "tokenUsage": { "$ref": "#/definitions/tokenUsage" },
        "costEstimate": { "type": "string" },
        "configProfileId": { "type": "string" },
        "policyReferences": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "createdRecords": { "$ref": "#/definitions/createdRecords" }
      }
    }
  }
}
