{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/admin-intake-decision.json",
  "title": "AdminIntakeDecision",
  "description": "Admin decision for an AI source-role/scope intake suggestion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decisionId",
    "intakeSourceId",
    "sessionId",
    "caseId",
    "decidedBy",
    "decidedAt",
    "decision",
    "preservesOriginalSuggestion"
  ],
  "properties": {
    "decisionId": { "type": "string", "minLength": 1 },
    "intakeSourceId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "suggestionId": { "type": "string", "minLength": 1 },
    "decidedBy": { "type": "string", "minLength": 1 },
    "decidedAt": { "type": "string", "format": "date-time" },
    "decision": {
      "type": "string",
      "enum": [
        "confirmed_ai_suggestion",
        "edited_ai_suggestion",
        "overridden_by_admin",
        "marked_needs_review"
      ]
    },
    "finalSourceRole": { "type": "string" },
    "finalScope": {
      "type": "string",
      "enum": ["company_level", "department_level", "team_unit_level", "role_level", "person_level", "shared", "unknown"]
    },
    "reason": { "type": "string" },
    "preservesOriginalSuggestion": { "type": "boolean" }
  }
}
