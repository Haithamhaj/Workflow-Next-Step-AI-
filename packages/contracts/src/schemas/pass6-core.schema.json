{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/pass6-core.json",
  "title": "Pass6CoreContracts",
  "description": "Pass 6 Block 1 contract/schema seams only. These shapes define cross-block handoff data and do not implement analysis, persistence, provider execution, package generation, visual rendering, Copilot writes, or Pass 7 mechanics.",
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "optionalString": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["referenceId", "referenceType"],
      "properties": {
        "referenceId": { "$ref": "#/definitions/nonEmptyString" },
        "referenceType": { "$ref": "#/definitions/nonEmptyString" },
        "label": { "$ref": "#/definitions/optionalString" },
        "sourceId": { "$ref": "#/definitions/optionalString" },
        "sessionId": { "$ref": "#/definitions/optionalString" },
        "evidenceItemId": { "$ref": "#/definitions/optionalString" },
        "quote": { "$ref": "#/definitions/optionalString" },
        "notes": { "$ref": "#/definitions/optionalString" }
      }
    },
    "sourceBasis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basisId", "basisType", "references"],
      "properties": {
        "basisId": { "$ref": "#/definitions/nonEmptyString" },
        "basisType": {
          "type": "string",
          "enum": ["pass5_output", "raw_evidence", "extraction", "clarification", "boundary_signal", "handoff_candidate", "admin_note", "source_document", "method_output", "other"]
        },
        "summary": { "$ref": "#/definitions/optionalString" },
        "references": {
          "type": "array",
          "items": { "$ref": "#/definitions/reference" }
        }
      }
    },
    "roleLayerContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contextId"],
      "properties": {
        "contextId": { "$ref": "#/definitions/nonEmptyString" },
        "participantId": { "$ref": "#/definitions/optionalString" },
        "sessionId": { "$ref": "#/definitions/optionalString" },
        "targetCandidateId": { "$ref": "#/definitions/optionalString" },
        "participantRole": { "$ref": "#/definitions/optionalString" },
        "hierarchyNodeId": { "$ref": "#/definitions/optionalString" },
        "department": { "$ref": "#/definitions/optionalString" },
        "selectedUseCase": { "$ref": "#/definitions/optionalString" },
        "layer": { "$ref": "#/definitions/optionalString" },
        "groupingLayerCategory": { "$ref": "#/definitions/optionalString" },
        "levelHint": { "$ref": "#/definitions/optionalString" },
        "inUseCaseScope": { "type": "boolean" },
        "participantTargetType": { "$ref": "#/definitions/optionalString" },
        "authorityScope": { "$ref": "#/definitions/optionalString" },
        "notes": { "$ref": "#/definitions/optionalString" }
      }
    },
    "truthLensContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contextId", "lensType"],
      "properties": {
        "contextId": { "$ref": "#/definitions/nonEmptyString" },
        "lensType": {
          "type": "string",
          "enum": ["execution_evidence", "oversight_evidence", "approval_control_evidence", "policy_intent_evidence", "handoff_dependency_evidence", "document_signal_evidence"]
        },
        "summary": { "$ref": "#/definitions/optionalString" },
        "limitations": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        }
      }
    },
    "preparedMaterialItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["itemId", "itemType", "summary", "basis"],
      "properties": {
        "itemId": { "$ref": "#/definitions/nonEmptyString" },
        "itemType": { "$ref": "#/definitions/nonEmptyString" },
        "summary": { "$ref": "#/definitions/nonEmptyString" },
        "basis": { "$ref": "#/definitions/sourceBasis" },
        "roleLayerContextIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "truthLensContextIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "notes": { "$ref": "#/definitions/optionalString" }
      }
    },
    "preparationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["preparedBy", "summary", "noDropNotes"],
      "properties": {
        "preparedBy": {
          "type": "string",
          "enum": ["system", "admin", "system_with_admin_review"]
        },
        "summary": { "$ref": "#/definitions/nonEmptyString" },
        "acceptedPass5Only": { "type": "boolean" },
        "doesNotRevalidatePass5": { "type": "boolean" },
        "noDropNotes": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        }
      }
    },
    "synthesisInputBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundleId",
        "caseId",
        "createdAt",
        "sourcePass5SessionIds",
        "analysis_material",
        "boundary_role_limit_material",
        "gap_risk_no_drop_material",
        "document_source_signal_material",
        "roleLayerContexts",
        "truthLensContexts",
        "preparationSummary"
      ],
      "properties": {
        "bundleId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "createdAt": { "$ref": "#/definitions/timestamp" },
        "sourcePass5SessionIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "analysis_material": {
          "type": "array",
          "items": { "$ref": "#/definitions/preparedMaterialItem" }
        },
        "boundary_role_limit_material": {
          "type": "array",
          "items": { "$ref": "#/definitions/preparedMaterialItem" }
        },
        "gap_risk_no_drop_material": {
          "type": "array",
          "items": { "$ref": "#/definitions/preparedMaterialItem" }
        },
        "document_source_signal_material": {
          "type": "array",
          "items": { "$ref": "#/definitions/preparedMaterialItem" }
        },
        "roleLayerContexts": {
          "type": "array",
          "items": { "$ref": "#/definitions/roleLayerContext" }
        },
        "truthLensContexts": {
          "type": "array",
          "items": { "$ref": "#/definitions/truthLensContext" }
        },
        "preparationSummary": { "$ref": "#/definitions/preparationSummary" }
      }
    },
    "workflowUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unitId", "caseId", "bundleId", "unitType", "unitText", "basis"],
      "properties": {
        "unitId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "bundleId": { "$ref": "#/definitions/nonEmptyString" },
        "unitType": {
          "type": "string",
          "enum": ["action_step", "trigger_input", "output_outcome", "sequence_signal", "decision_rule", "approval_control", "handoff", "exception", "boundary", "information_context", "unknown_gap"]
        },
        "unitText": { "$ref": "#/definitions/nonEmptyString" },
        "roleLayerContextId": { "$ref": "#/definitions/optionalString" },
        "basis": { "$ref": "#/definitions/sourceBasis" },
        "notes": { "$ref": "#/definitions/optionalString" }
      }
    },
    "workflowClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimId", "caseId", "bundleId", "primaryClaimType", "normalizedStatement", "unitIds", "basis", "status"],
      "properties": {
        "claimId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "bundleId": { "$ref": "#/definitions/nonEmptyString" },
        "primaryClaimType": {
          "type": "string",
          "enum": ["execution_claim", "sequence_claim", "decision_rule_claim", "ownership_claim", "boundary_claim"]
        },
        "secondaryClaimTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["execution_claim", "sequence_claim", "decision_rule_claim", "ownership_claim", "boundary_claim"]
          }
        },
        "claimText": { "$ref": "#/definitions/optionalString" },
        "normalizedStatement": { "$ref": "#/definitions/nonEmptyString" },
        "sourceParticipantIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "sourceSessionIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "sourceLayerContextIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "truthLensContextIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "unitIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "basis": { "$ref": "#/definitions/sourceBasis" },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "materiality": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "accepted_for_assembly", "warning", "unresolved", "review_needed"]
        }
      }
    },
    "analysisMethodUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["methodUsageId", "methodId", "methodKey", "methodName", "methodType", "version", "selectionReason", "selectionSource", "appliedToType", "appliedToId", "outputSummary", "impact", "suitabilityAssessment"],
      "properties": {
        "methodUsageId": { "$ref": "#/definitions/nonEmptyString" },
        "methodId": { "$ref": "#/definitions/nonEmptyString" },
        "methodKey": {
          "type": "string",
          "enum": ["bpmn_process_structure", "sipoc_boundary", "triangulation", "espoused_theory_vs_theory_in_use", "raci_responsibility", "ssm_multi_perspective", "apqc_vocabulary"]
        },
        "methodName": { "$ref": "#/definitions/nonEmptyString" },
        "methodType": {
          "type": "string",
          "enum": ["process_structure_lens", "boundary_lens", "evidence_lens", "practice_reality_lens", "responsibility_lens", "multi_perspective_lens", "vocabulary_lens"]
        },
        "version": { "$ref": "#/definitions/nonEmptyString" },
        "selectionReason": { "$ref": "#/definitions/nonEmptyString" },
        "selectionSource": {
          "type": "string",
          "enum": ["system_selected", "admin_forced"]
        },
        "methodRole": {
          "type": "string",
          "enum": ["primary", "secondary", "supporting", "admin_forced"]
        },
        "appliedToType": {
          "type": "string",
          "enum": ["bundle", "workflow_unit", "claim", "difference", "workflow_draft", "readiness_assessment", "gap", "package_section"]
        },
        "appliedToId": { "$ref": "#/definitions/nonEmptyString" },
        "outputSummary": { "$ref": "#/definitions/nonEmptyString" },
        "impact": {
          "type": "object",
          "additionalProperties": false,
          "required": ["affectedIds", "impactSummary"],
          "properties": {
            "affectedIds": {
              "type": "array",
              "items": { "$ref": "#/definitions/nonEmptyString" }
            },
            "impactSummary": { "$ref": "#/definitions/nonEmptyString" },
            "changedRouting": { "type": "boolean" },
            "changedReadiness": { "type": "boolean" }
          }
        },
        "suitabilityAssessment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["suitable", "notes"],
          "properties": {
            "suitable": { "type": "boolean" },
            "notes": { "$ref": "#/definitions/nonEmptyString" },
            "limitations": {
              "type": "array",
              "items": { "$ref": "#/definitions/nonEmptyString" }
            }
          }
        }
      }
    },
    "differenceInterpretation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["differenceId", "caseId", "involvedClaimIds", "differenceType", "recommendedRoute", "explanation"],
      "properties": {
        "differenceId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "involvedClaimIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "involvedLayers": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "involvedRoles": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "differenceType": {
          "type": "string",
          "enum": ["completion", "variant", "normative_reality_mismatch", "factual_conflict"]
        },
        "materiality": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "recommendedRoute": {
          "type": "string",
          "enum": ["carry_as_completion", "carry_as_variant", "warning", "clarification_needed", "review_candidate", "blocker_candidate"]
        },
        "explanation": { "$ref": "#/definitions/nonEmptyString" },
        "methodUsageIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "notPerformanceEvaluation": { "type": "boolean" }
      }
    },
    "workflowElement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elementId", "label"],
      "properties": {
        "elementId": { "$ref": "#/definitions/nonEmptyString" },
        "label": { "$ref": "#/definitions/nonEmptyString" },
        "description": { "$ref": "#/definitions/optionalString" },
        "claimIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "basis": { "$ref": "#/definitions/sourceBasis" }
      }
    },
    "claimBasisEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflowElementId", "claimIds"],
      "properties": {
        "workflowElementId": { "$ref": "#/definitions/nonEmptyString" },
        "claimIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "sourceUnitIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "participantIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "sessionIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "layerContextIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "truthLensContextIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "methodUsageIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "differenceIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "basis": { "$ref": "#/definitions/sourceBasis" },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "materiality": {
          "type": "string",
          "enum": ["high", "medium", "low", "unknown"]
        },
        "notes": { "$ref": "#/definitions/optionalString" }
      }
    },
    "assembledWorkflowDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draftId", "caseId", "basedOnBundleId", "workflowUnderstandingLevel", "steps", "sequence", "decisions", "handoffs", "controls", "systemsTools", "variants", "warningsCaveats", "unresolvedItems", "claimBasisMap", "metadata"],
      "properties": {
        "draftId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "basedOnBundleId": { "$ref": "#/definitions/nonEmptyString" },
        "workflowUnderstandingLevel": {
          "type": "string",
          "enum": ["partial_workflow_understanding", "reconstructable_workflow_with_gaps", "package_ready_workflow", "workflow_exists_but_not_package_ready"]
        },
        "steps": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "sequence": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "decisions": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "handoffs": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "controls": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "systemsTools": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "variants": { "type": "array", "items": { "$ref": "#/definitions/workflowElement" } },
        "warningsCaveats": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "unresolvedItems": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
        "claimBasisMap": { "type": "array", "items": { "$ref": "#/definitions/claimBasisEntry" } },
        "metadata": { "$ref": "#/definitions/recordMetadata" }
      }
    },
    "conditionAssessmentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rationale", "basis", "blocksInitialPackage"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["clear_enough", "warning", "materially_broken", "unknown", "not_applicable"]
        },
        "rationale": { "$ref": "#/definitions/nonEmptyString" },
        "basis": { "$ref": "#/definitions/sourceBasis" },
        "blocksInitialPackage": { "type": "boolean" }
      }
    },
    "sevenConditionAssessmentMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_sequence_continuity", "step_to_step_connection", "essential_step_requirements", "decision_rules_thresholds", "handoffs_responsibility", "controls_approvals", "use_case_boundary"],
      "properties": {
        "core_sequence_continuity": { "$ref": "#/definitions/conditionAssessmentItem" },
        "step_to_step_connection": { "$ref": "#/definitions/conditionAssessmentItem" },
        "essential_step_requirements": { "$ref": "#/definitions/conditionAssessmentItem" },
        "decision_rules_thresholds": { "$ref": "#/definitions/conditionAssessmentItem" },
        "handoffs_responsibility": { "$ref": "#/definitions/conditionAssessmentItem" },
        "controls_approvals": { "$ref": "#/definitions/conditionAssessmentItem" },
        "use_case_boundary": { "$ref": "#/definitions/conditionAssessmentItem" }
      }
    },
    "sevenConditionAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assessmentId", "caseId", "assembledWorkflowDraftId", "conditions", "overallSummary"],
      "properties": {
        "assessmentId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "assembledWorkflowDraftId": { "$ref": "#/definitions/nonEmptyString" },
        "conditions": { "$ref": "#/definitions/sevenConditionAssessmentMap" },
        "overallSummary": { "$ref": "#/definitions/nonEmptyString" }
      }
    },
    "workflowReadinessResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resultId", "caseId", "assembledWorkflowDraftId", "readinessDecision", "sevenConditionAssessment", "gapRiskSummary", "allowedUseFor6C", "routingRecommendations", "analysisMetadata", "is6CAllowed"],
      "properties": {
        "resultId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "assembledWorkflowDraftId": { "$ref": "#/definitions/nonEmptyString" },
        "readinessDecision": {
          "type": "string",
          "enum": ["ready_for_initial_package", "ready_for_initial_package_with_warnings", "partial_only_not_package_ready", "needs_more_clarification_before_package", "needs_review_decision_before_package", "workflow_exists_but_current_basis_insufficient"]
        },
        "sevenConditionAssessment": { "$ref": "#/definitions/sevenConditionAssessment" },
        "gapRiskSummary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["summary", "gapIds", "riskIds"],
          "properties": {
            "summary": { "$ref": "#/definitions/nonEmptyString" },
            "gapIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } },
            "riskIds": { "type": "array", "items": { "$ref": "#/definitions/nonEmptyString" } }
          }
        },
        "allowedUseFor6C": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["initial_package", "initial_package_with_warnings", "gap_closure_brief", "draft_operational_document", "none"]
          }
        },
        "routingRecommendations": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "analysisMetadata": { "$ref": "#/definitions/recordMetadata" },
        "is6CAllowed": { "type": "boolean" }
      }
    },
    "clarificationNeed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clarificationNeedId", "questionType", "questionText", "whyItMatters", "expectedAnswerType", "blockingStatus", "basis", "recommendedChannel", "priority"],
      "properties": {
        "clarificationNeedId": { "$ref": "#/definitions/nonEmptyString" },
        "questionType": {
          "type": "string",
          "enum": ["open_question", "open_question_with_helper_choices", "choice_based_with_optional_explanation", "meeting_agenda_item", "formal_email_inquiry", "admin_review_decision"]
        },
        "questionText": { "$ref": "#/definitions/nonEmptyString" },
        "targetRecipient": { "$ref": "#/definitions/optionalString" },
        "targetRole": { "$ref": "#/definitions/optionalString" },
        "whyItMatters": { "$ref": "#/definitions/nonEmptyString" },
        "relatedWorkflowElementId": { "$ref": "#/definitions/optionalString" },
        "relatedGapId": { "$ref": "#/definitions/optionalString" },
        "relatedSevenConditionKey": {
          "type": "string",
          "enum": ["core_sequence_continuity", "step_to_step_connection", "essential_step_requirements", "decision_rules_thresholds", "handoffs_responsibility", "controls_approvals", "use_case_boundary", "unknown"]
        },
        "relatedClaimIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "relatedDifferenceIds": {
          "type": "array",
          "items": { "$ref": "#/definitions/nonEmptyString" }
        },
        "expectedAnswerType": {
          "type": "string",
          "enum": ["free_text", "yes_no", "owner_name", "threshold_value", "system_name", "document_reference", "sequence_order", "approval_rule", "other"]
        },
        "exampleAnswer": { "$ref": "#/definitions/optionalString" },
        "blockingStatus": {
          "type": "string",
          "enum": ["blocking", "non_blocking"]
        },
        "basis": { "$ref": "#/definitions/sourceBasis" },
        "recommendedChannel": {
          "type": "string",
          "enum": ["admin_review", "participant_follow_up", "manager_follow_up", "source_document_review", "external_interface_review", "other"]
        },
        "priority": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    },
    "inquiryPacket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inquiryPacketId", "caseId", "clarificationNeeds", "packetStatus", "createdAt"],
      "properties": {
        "inquiryPacketId": { "$ref": "#/definitions/nonEmptyString" },
        "caseId": { "$ref": "#/definitions/nonEmptyString" },
        "targetRole": { "$ref": "#/definitions/optionalString" },
        "targetRecipient": { "$ref": "#/definitions/optionalString" },
        "clarificationNeeds": {
          "type": "array",
          "items": { "$ref": "#/definitions/clarificationNeed" }
        },
        "packetStatus": {
          "type": "string",
          "enum": ["draft_not_sent", "ready_for_admin_review", "superseded"]
        },
        "createdAt": { "$ref": "#/definitions/timestamp" }
      }
    },
    "prePackageGateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateResultId", "caseId", "workflowReadinessResultId", "gateDecision", "clarificationNeeds", "inquiryPackets"],
      "properties": {
