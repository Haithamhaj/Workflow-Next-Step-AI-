{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/source-hierarchy-triage-suggestion.json",
  "title": "SourceHierarchyTriageSuggestion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "triageId",
    "sessionId",
    "companyId",
    "caseId",
    "sourceId",
    "sourceName",
    "suggestedScope",
    "signalType",
    "suggestedReason",
    "confidence",
    "evidenceStatus",
    "participantValidationNeeded",
    "adminReviewQuestion",
    "adminDecision",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "triageId": { "type": "string", "minLength": 1 },
    "triageJobId": { "type": "string" },
    "sessionId": { "type": "string", "minLength": 1 },
    "companyId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "sourceId": { "type": "string", "minLength": 1 },
    "sourceName": { "type": "string", "minLength": 1 },
    "suggestedScope": { "$ref": "#/definitions/suggestedScope" },
    "linkedNodeId": { "type": "string" },
    "linkedScopeLevel": { "$ref": "#/definitions/suggestedScope" },
    "signalType": {
      "type": "string",
      "enum": [
        "role_name_signal",
        "department_scope_signal",
        "kpi_or_target_signal",
        "responsibility_signal",
        "approval_or_authority_signal",
        "system_or_queue_signal",
        "person_name_signal",
        "cross_functional_signal",
        "external_interface_signal",
        "unclear_scope_signal"
      ]
    },
    "suggestedReason": { "type": "string" },
    "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
    "evidenceStatus": {
      "type": "string",
      "enum": [
        "document_claim_only",
        "admin_confirmed_relevance",
        "participant_validation_needed",
        "rejected_by_admin",
        "scope_changed_by_admin"
      ]
    },
    "participantValidationNeeded": { "type": "boolean" },
    "adminReviewQuestion": { "type": "string" },
    "adminDecision": {
      "type": "string",
      "enum": [
        "pending_review",
        "accepted_link",
        "rejected_link",
        "changed_scope",
        "participant_validation_needed",
        "admin_note_added"
      ]
    },
    "adminNote": { "type": "string" },
    "provider": { "type": "string", "enum": ["google", "openai"] },
    "model": { "type": "string" },
    "promptSpecId": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  },
  "definitions": {
    "suggestedScope": {
      "type": "string",
      "enum": [
        "company_wide",
        "department_wide",
        "team_or_unit",
        "role_specific",
        "person_or_occupant",
        "system_or_queue",
        "approval_or_control_node",
        "external_interface",
        "unknown_needs_review"
      ]
    }
  }
}
