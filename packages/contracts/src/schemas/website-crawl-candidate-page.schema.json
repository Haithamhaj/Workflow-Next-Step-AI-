{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/website-crawl-candidate-page.json",
  "title": "WebsiteCrawlCandidatePage",
  "description": "Candidate page discovered during crawl planning (Pass 2 Phase 1 contract).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidatePageId",
    "crawlPlanId",
    "url",
    "depth",
    "discoveredAt",
    "status"
  ],
  "properties": {
    "candidatePageId": { "type": "string", "minLength": 1 },
    "crawlPlanId": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "depth": { "type": "integer", "minimum": 0 },
    "discoveredAt": { "type": "string", "format": "date-time" },
    "previewRef": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["discovered", "pending_approval", "approved", "rejected", "fetched"]
    }
  }
}
