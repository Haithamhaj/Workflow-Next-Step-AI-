{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/hierarchy-readiness-snapshot.json",
  "title": "HierarchyReadinessSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["readinessSnapshotId", "sessionId", "caseId", "status", "nodeCount", "relationshipCount", "reasons", "pass4Boundary", "createdAt"],
  "properties": {
    "readinessSnapshotId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "caseId": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["blocked", "ready_for_participant_targeting_planning"] },
    "approvedSnapshotId": { "type": "string" },
    "nodeCount": { "type": "integer", "minimum": 0 },
    "relationshipCount": { "type": "integer", "minimum": 0 },
    "reasons": { "type": "array", "items": { "type": "string" } },
    "pass4Boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participantTargetingCreated", "rolloutOrderCreated", "sessionsCreated"],
      "properties": {
        "participantTargetingCreated": { "const": false },
        "rolloutOrderCreated": { "const": false },
        "sessionsCreated": { "const": false }
      }
    },
    "createdAt": { "type": "string", "minLength": 1 }
  }
}
