{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/company.json",
  "title": "Company",
  "description": "Top-level company identity for multi-company isolation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["companyId", "displayName", "status", "createdAt", "updatedAt"],
  "properties": {
    "companyId": {
      "type": "string",
      "minLength": 1
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "archived"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "externalRef": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
