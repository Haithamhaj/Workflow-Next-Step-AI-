{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://workflow.local/schemas/prompt-spec.json",
  "title": "StructuredPromptSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["promptSpecId", "linkedModule", "purpose", "status", "version", "blocks", "createdAt", "updatedAt"],
  "properties": {
    "promptSpecId": { "type": "string", "minLength": 1 },
    "linkedModule": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "previous", "archived"] },
    "version": { "type": "integer", "minimum": 1 },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blockId", "label", "body", "editable"],
        "properties": {
          "blockId": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "body": { "type": "string" },
          "editable": { "type": "boolean" }
        }
      }
    },
    "inputContractRef": { "type": "string" },
    "outputContractRef": { "type": "string" },
    "previousActivePromptSpecId": { "type": "string" },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 }
  }
}
