# Provider configuration examples only. Do not commit real keys.
# Do not commit real keys. Copy this file to a local ignored env file and set values there.

# Pass 5 and later text intelligence / prompt execution default:
# OpenAI / GPT is the default for participant guidance, first-pass extraction,
# clarification formulation, answer recheck, admin assistant, and complex scenario proof.
WORKFLOW_PASS5_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# Google remains configured for earlier Google/Gemini-backed surfaces and
# voice / speech-to-text / image / OCR-style capabilities where used.
GOOGLE_AI_API_KEY=

# Optional Google text/OCR model. Defaults to gemini-3.1-pro-preview when unset.
GOOGLE_AI_MODEL=gemini-3.1-pro-preview

# Google Speech-to-Text configuration is local-env only when needed.
GOOGLE_STT_API_KEY=
GOOGLE_STT_MODEL=latest_long
GOOGLE_STT_LANGUAGE_CODE=en-US
