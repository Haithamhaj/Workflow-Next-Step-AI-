# Google AI provider for Pass 3 provider-backed hierarchy and source triage.
# Do not commit real keys. Copy this file to a local ignored env file and set values there.
GOOGLE_AI_API_KEY=

# Optional. Defaults to gemini-3.1-pro-preview when unset.
GOOGLE_AI_MODEL=gemini-3.1-pro-preview

# Optional Pass 5 live-proof provider override. Defaults to google when unset.
# Set to openai to use the OpenAI live prompt provider for Pass 5 proofs.
WORKFLOW_PASS5_PROVIDER=google
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
