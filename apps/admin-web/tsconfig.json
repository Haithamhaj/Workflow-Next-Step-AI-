{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "app/**/*.ts", "app/**/*.tsx", "components/**/*.ts", "components/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/contracts" },
    { "path": "../../packages/core-state" },
    { "path": "../../packages/persistence" },
    { "path": "../../packages/stage-copilot" },
    { "path": "../../packages/core-case" },
    { "path": "../../packages/sources-context" },
    { "path": "../../packages/prompts" },
    { "path": "../../packages/sessions-clarification" },
    { "path": "../../packages/synthesis-evaluation" },
    { "path": "../../packages/packages-output" }
    ,{ "path": "../../packages/review-issues" }
  ]
}
